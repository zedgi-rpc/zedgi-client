{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["es2023", "dom"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "composite": false,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
