{
  "name": "@zedgi/zedgi-client",
  "version": "1.0.0",
  "description": "Zedgi client SDK — call Redis, Postgres, and MySQL from any HTTP runtime.",
  "private": false,
  "license": "MIT",
  "author": "Olaoluwa <olaoluwa@zedgi.app>",
  "homepage": "https://zedgi.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/zedgi-rpc/zedgi-client.git"
  },
  "bugs": {
    "url": "https://github.com/zedgi-rpc/zedgi-client/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "zintrust",
    "zedgi",
    "redis",
    "postgres",
    "mysql",
    "rpc",
    "proxy",
    "edge",
    "serverless",
    "cloudflare-workers"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-dist-esm-imports.mjs dist",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "npm run build"
  }
}
